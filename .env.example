# ─────────────────────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────────────────────
# URL pública del proyecto (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
# Clave de service_role. SOLO se usa en el servidor (server actions /
# server components). NUNCA exponer en el cliente.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ─────────────────────────────────────────────────────────────
# WhatsApp Cloud API (Meta)
# ─────────────────────────────────────────────────────────────
# Token de acceso (System User para producción; el de prueba caduca ~24 hs).
WHATSAPP_TOKEN=EAA...
# ID del número remitente (WhatsApp → API Setup → Phone number ID).
WHATSAPP_PHONE_NUMBER_ID=1234567890
# Versión de la Graph API (opcional).
WHATSAPP_API_VERSION=v21.0
# Teléfono del dueño/barbero que recibe las notificaciones de reserva.
BARBERO_TELEFONO=+5491100000000

# ─────────────────────────────────────────────────────────────
# Acceso al panel administrativo
# Se usa como contraseña Y como secreto para firmar la cookie de sesión.
# ─────────────────────────────────────────────────────────────
ADMIN_PASSWORD=cambia-esta-clave

# ─────────────────────────────────────────────────────────────
# Cron de recordatorios (Vercel agrega Authorization: Bearer $CRON_SECRET)
# ─────────────────────────────────────────────────────────────
CRON_SECRET=un-secreto-largo-y-aleatorio

# URL pública del sitio (para Open Graph). En Vercel ya se infiere.
NEXT_PUBLIC_SITE_URL=https://wallss.vercel.app
